{
  "mcpServers": {
    "gitlab": {
      "command": "uvx",
      "args": ["mcp-server-gitlab"],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_API_URL": "${GITLAB_API_URL:-https://gitlab.com/api/v4}"
      }
    },
    "postgres": {
      "command": "uvx",
      "args": ["postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "${DATABASE_URL:-postgresql://user:password@localhost:5432/dbname}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "rabbitmq": {
      "command": "uvx",
      "args": [
        "mcp-server-rabbitmq",
        "--rabbitmq-host", "${RABBITMQ_HOST:-localhost}",
        "--port", "${RABBITMQ_PORT:-5672}",
        "--username", "${RABBITMQ_USER:-guest}",
        "--password", "${RABBITMQ_PASSWORD:-guest}",
        "--api-port", "${RABBITMQ_API_PORT:-15672}"
      ]
    },
    "elasticsearch": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "ES_URL",
        "-e", "ES_API_KEY",
        "docker.elastic.co/mcp/elasticsearch",
        "stdio"
      ],
      "env": {
        "ES_URL": "${ELASTICSEARCH_URL:-http://localhost:9200}",
        "ES_API_KEY": "${ELASTICSEARCH_API_KEY}"
      }
    },
    "redis": {
      "command": "uvx",
      "args": [
        "--from", "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url", "${REDIS_URL:-redis://localhost:6379/0}"
      ]
    },
    "docker": {
      "command": "uvx",
      "args": ["docker-mcp"]
    },
    "seq": {
      "command": "seq-mcp-server",
      "env": {
        "SEQ_SERVER_URL": "${SEQ_SERVER_URL:-http://localhost:5341}",
        "SEQ_API_KEY": "${SEQ_API_KEY}"
      }
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "mcp-server-kubernetes"],
      "env": {
        "ALLOW_ONLY_NON_DESTRUCTIVE_TOOLS": "${K8S_READONLY:-false}"
      }
    }
  }
}
