{
    "includeCoAuthoredBy": false,
    "alwaysThinkingEnabled": false,
    "permissions": {
        "deny": [
            "Read(.env)",
            "Read(.env.*)",
            "Read(./**/.env)",
            "Read(./**/.env.*)",
            "Read(*.key)",
            "Read(*.pem)",
            "Read(secrets/**)",
            "Read(run-claude/**)"
        ]
    }
}