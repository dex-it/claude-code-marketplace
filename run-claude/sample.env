# ==================== Глобальные переменные ====================
# Confluence MCP сервер (оставить пусто, если не используется)
CONFLUENCE_MCP_URL=https://confluence.mcp.dex-it.ru
CONFLUENCE_MCP_TOKEN=<PAT>

# Jira MCP сервер (оставить пусто, если не используется)
JIRA_MCP_URL=https://jira.mcp.dex-it.ru
JIRA_MCP_TOKEN=<PAT>

# GitLab (может быть общий для всех проектов)
GITLAB_TOKEN=glpat-xxx

# ==================== Переменные для этого проекта ====================
# PostgreSQL база данных
DATABASE_URL=postgresql://postgres:pass@localhost:5432/db

# Elasticsearch (опционально)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=xxx

# Seq логирование (опционально)
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=xxx

# Notion документация (опционально)
NOTION_API_KEY=ntn_xxx

# MLflow для ML проектов (опционально)
MLFLOW_TRACKING_URI=http://localhost:5000

# ==================== Параметры запуска Claude Code ====================
# Дефолтные ключи запуска Claude Code
#
# Системный промпт автоматически загружается из файла:
# ./run-claude/system-prompt.md
#
# Если нужно добавить дополнительный текст к промпту, используй --append-system-prompt
#
# Примеры:
# CLAUDE_ARGS=--allow-dangerously-skip-permissions                                    # разрешим не спрашивать
# CLAUDE_ARGS=--settings ./run-claude/settings.json --append-system-prompt "Extra"    # добавим доп. инструкции
# CLAUDE_ARGS=--mcp-config ./run-claude/.mcp.json --strict-mcp-config                 # загрузим MCP только отсюда
#
# По умолчанию батник:
# 1. Загружает промпт из ./run-claude/prompts/system-prompt.md
# 2. Добавляет его через --append-system-prompt
# 3. Комбинирует с CLAUDE_ARGS из этой переменной
#
CLAUDE_ARGS=--settings ./run-claude/settings.json
