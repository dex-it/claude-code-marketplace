# ==============================================
# Git Integration
# ==============================================
GITLAB_TOKEN=glpat-xxx
# (Optional) Self-hosted GitLab API URL
# По умолчанию: https://gitlab.com/api/v4
GITLAB_API_URL=https://gitlab.com/api/v4
GITHUB_TOKEN=

# ==============================================
# Documentation & Project Management
# ==============================================
NOTION_TOKEN=ntn_xxx

# ==============================================
# System Analyst Tools
# ==============================================
# Google Drive MCP (требует OAuth credentials)
# Инструкция: https://console.cloud.google.com → Create OAuth Client ID → Desktop app
GOOGLE_DRIVE_OAUTH_CREDENTIALS=~/.config/google-drive-mcp/oauth-credentials.json

# ==============================================
# Database & Storage (.NET Plugins) - genai-toolbox
# ==============================================
# Базы данных конфигурируются в tools.yaml для genai-toolbox MCP
# Пример конфигурации: mcp/examples/toolbox-config.yaml
# Docs: https://github.com/googleapis/genai-toolbox
#
# Эти переменные используются в tools.yaml:
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=app
DATABASE_USER=postgres
DATABASE_PASSWORD=password
MONGODB_URI=mongodb://localhost:27017/dbname
REDIS_URL=localhost:6379
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ==============================================
# Message Queues (.NET Plugins)
# ==============================================
# RabbitMQ: Подключение через MCP tool rabbitmq_broker_initialize_connection()
# Переменные окружения не требуются - параметры передаются в tool

# ==============================================
# Apache Kafka (.NET Plugins)
# ==============================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kafka-mcp-server
# SASL Authentication (optional)
# Supported mechanisms: plain, scram-sha-256, scram-sha-512
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_TLS_ENABLE=false

# ==============================================
# Logging & Monitoring (.NET Plugins)
# ==============================================
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=xxx
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ==============================================
# CI/CD (.NET Plugins)
# ==============================================
TEAMCITY_URL=https://teamcity.example.com
TEAMCITY_TOKEN=
MCP_MODE=dev

# ==============================================
# Container Orchestration (.NET Plugins)
# ==============================================
K8S_READONLY=true

# ==============================================
# ML/AI Tools (Python ML Plugin)
# ==============================================
MLFLOW_TRACKING_URI=
WANDB_API_KEY=
HUGGINGFACE_TOKEN=

# ==============================================
# MCP Servers (Model Context Protocol)
# ==============================================
CONFLUENCE_MCP_URL=
CONFLUENCE_MCP_TOKEN=<PAT>
JIRA_MCP_URL=
JIRA_MCP_TOKEN=<PAT>

# ==============================================
# Telegram Notifications (dex-telegram-notifier)
# ==============================================
# Создайте бота через @BotFather в Telegram
# Получите Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Язык сообщений (ru/en)
TELEGRAM_LANGUAGE=ru
# Опциональные настройки:
# TELEGRAM_NOTIFY_STOP=true
# TELEGRAM_NOTIFY_WAITING=true
# TELEGRAM_NOTIFY_SUBAGENT=true
# TELEGRAM_INCLUDE_MESSAGE=true
# TELEGRAM_INCLUDE_THINKING=false
# TELEGRAM_INCLUDE_TODO=true
# TELEGRAM_INCLUDE_TOOLS=true
# TELEGRAM_INCLUDE_PLAN=true
# TELEGRAM_INCLUDE_QUESTIONS=true
# TELEGRAM_MESSAGE_LIMIT=4000
# TELEGRAM_THREAD_ID=              # Для топиков в супергруппах

# ==============================================
# Discord Notifications (dex-discord-notifier)
# ==============================================
DISCORD_NOTIFIER_URL=
# Язык сообщений (ru/en)
DISCORD_LANGUAGE=ru
# Опциональные настройки:
# DISCORD_NOTIFY_STOP=true
# DISCORD_NOTIFY_PERMISSIONS=true
# DISCORD_NOTIFY_WAITING=true
# DISCORD_NOTIFY_SUBAGENT=true
# DISCORD_INCLUDE_MESSAGE=true
# DISCORD_INCLUDE_THINKING=false
# DISCORD_INCLUDE_TODO=true
# DISCORD_INCLUDE_TOOLS=true
# DISCORD_INCLUDE_PLAN=true
# DISCORD_INCLUDE_QUESTIONS=true
# DISCORD_MESSAGE_LIMIT=4000

# ==============================================
# Дефолтные ключи запуска Claude Code
# ==============================================

# Управление загрузкой системного промпта
# По умолчанию: true (загружать из ./run-claude/system-prompt.md)
# Установите false для отключения загрузки системного промпта
LOAD_SYSTEM_PROMPT=true

#
# ВАЖНО: Системный промпт автоматически загружается из файла:
#        ./run-claude/system-prompt.md
#
# Скрипты (run-claude.sh, run-claude.ps1) автоматически:
# 1. Загружают промпт из ./run-claude/system-prompt.md
# 2. Добавляют его через --append-system-prompt
# 3. Комбинируют с CLAUDE_ARGS из этой переменной
#
# Примеры использования:
#
# Разрешить выполнение без запросов разрешений:
# CLAUDE_ARGS=--allow-dangerously-skip-permissions
#
# Загрузить MCP конфигурацию и настройки:
# CLAUDE_ARGS=--mcp-config ./run-claude/.mcp.json --strict-mcp-config --settings ./run-claude/settings.json
#
# Добавить ДОПОЛНИТЕЛЬНЫЙ текст к системному промпту:
# CLAUDE_ARGS=--settings ./run-claude/settings.json --append-system-prompt "Дополнительные инструкции"
#
# Выбрать модель:
# CLAUDE_ARGS=--model opus
# CLAUDE_ARGS=--model sonnet
#
CLAUDE_ARGS=--settings ./run-claude/settings.json
