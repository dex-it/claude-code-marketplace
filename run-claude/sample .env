# Дефолтные ключи запуска Claude Code
# Пример: CLAUDE_ARGS=--allow-dangerously-skip-permissions  # разрешим не спрашивать
# --mcp-config ./run-claude/.mcp.json --strict-mcp-config # загрузим mcp, только отсюда
# --settings ./run-claude/settings.json # загрузим общие настройки
CLAUDE_ARGS=--settings ./run-claude/settings.json --append-system-prompt "Задачи лежат в Jira(mcp), Описание задач, системная аналитика в Confluence(mcp)"
